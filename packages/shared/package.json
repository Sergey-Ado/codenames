{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./api": {
      "types": "./src/types/api.ts",
      "default": "./dist/types/api.js"
    },
    "./user": {
      "types": "./src/types/user.ts",
      "default": "./dist/types/user.js"
    },
